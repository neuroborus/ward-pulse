{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wardpulse.app/schemas/watch_dashboard_summary.schema.json",
  "title": "WatchDashboardSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "overallStatus",
    "today",
    "week",
    "providers",
    "alerts",
    "isStale"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "overallStatus": { "$ref": "dashboard_snapshot.schema.json#/$defs/providerStatus" },
    "today": {
      "allOf": [
        { "$ref": "budget_state.schema.json" },
        {
          "type": "object",
          "properties": { "period": { "const": "today" } }
        }
      ]
    },
    "week": {
      "allOf": [
        { "$ref": "budget_state.schema.json" },
        {
          "type": "object",
          "properties": { "period": { "const": "week" } }
        }
      ]
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "status", "todaySpent"],
        "properties": {
          "provider": { "$ref": "dashboard_snapshot.schema.json#/$defs/providerKind" },
          "status": { "$ref": "dashboard_snapshot.schema.json#/$defs/providerStatus" },
          "todaySpent": {
            "anyOf": [
              { "$ref": "budget_state.schema.json#/$defs/money" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "message"],
        "properties": {
          "severity": { "enum": ["info", "warning", "error"] },
          "message": { "type": "string" }
        }
      }
    },
    "isStale": { "type": "boolean" }
  }
}
